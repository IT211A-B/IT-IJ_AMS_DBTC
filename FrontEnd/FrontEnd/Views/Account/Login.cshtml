@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Attendance Management System</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
    <style>
        body { background: var(--green-dark); display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
        .login-card { display: flex; width: 820px; max-width: 100%; border-radius: 16px; overflow: hidden; box-shadow: 0 12px 48px rgba(0,0,0,0.28); }
        .login-brand { width: 46%; background: var(--green-mid); padding: 40px 32px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 14px; }
        .login-brand .brand-logo { width: 80px; height: 80px; border-radius: 50%; border: 3px solid rgba(255,255,255,0.35); background: rgba(255,255,255,0.12); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: rgba(255,255,255,0.7); }
        .login-brand h1 { font-size: 1.1rem; font-weight: 700; color: #fff; }
        .login-brand p  { font-size: 0.78rem; color: rgba(255,255,255,0.6); line-height: 1.5; }
        .login-form { flex: 1; background: #fff; padding: 40px 36px; display: flex; flex-direction: column; justify-content: center; }
        .login-form h2  { font-size: 1.3rem; font-weight: 700; color: var(--text); margin-bottom: 6px; }
        .login-form .sub { font-size: 0.8rem; color: var(--muted); margin-bottom: 26px; }
        .lfield { display: flex; flex-direction: column; gap: 5px; margin-bottom: 16px; }
        .lfield label { font-size: 0.8rem; font-weight: 600; color: var(--text); }
        .lfield input { height: 40px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 0 12px; font-size: 0.87rem; font-family: inherit; color: var(--text); transition: border-color var(--ease); }
        .lfield input:focus { outline: none; border-color: var(--green-dark); }
        .login-btn { width: 100%; height: 40px; background: var(--green-dark); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 0.88rem; font-weight: 600; font-family: inherit; cursor: pointer; margin-top: 8px; transition: background var(--ease); }
        .login-btn:hover { background: var(--green-mid); }
        .err-box { background: #fff3f3; border: 1px solid #ffcdd2; border-radius: var(--radius-sm); padding: 10px 13px; font-size: 0.82rem; color: var(--danger); margin-bottom: 14px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-brand">
            <div class="brand-logo">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <h1>Attendance Manager</h1>
            <p>Track student attendance across classes, courses, and teachers — all in one place.</p>
        </div>

        <div class="login-form">
            <h2>Sign in to Portal</h2>
            <p class="sub">Enter your credentials to continue</p>

            @if (ViewBag.ShowErrors == true)
            {
                <div class="err-box">
                    <i class="bi bi-exclamation-circle"></i>
                    @ViewBag.ErrorMessage
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="lfield">
                    <label>Username</label>
                    <input type="text" name="username" placeholder="Enter username" autofocus>
                </div>
                <div class="lfield">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="Enter password">
                </div>
                <button type="submit" class="login-btn">Sign In to Portal</button>
            </form>
        </div>
    </div>
</body>
</html>